{
  "name": "小微企业服务助手",
  "version": "1.0.0",
  "publisher": "中小企业联合会",
  "description": "帮助中小微企业把政策、融资准备、材料和合规风险先理清楚，优先提供公共服务型信息支持。",
  "modules": [
    {
      "id": "policy_query",
      "name": "政策找一找",
      "output": ["政策方向", "适用条件初筛", "官方入口", "材料清单", "核验提醒"]
    },
    {
      "id": "financing_prepare",
      "name": "融资准备助手",
      "output": ["融资场景判断", "可了解路径", "材料准备", "风险提醒", "下一步动作"]
    },
    {
      "id": "document_draft",
      "name": "材料生成工具",
      "output": ["文档初稿", "待确认字段", "提交前检查", "合规提示"]
    },
    {
      "id": "compliance_check",
      "name": "合规避坑问答",
      "output": ["风险等级", "风险点", "替代表达", "核验动作", "专业咨询建议"]
    },
    {
      "id": "operation_advice",
      "name": "小微经营知识库",
      "output": ["现状判断", "改进动作", "工具模板", "复盘节奏", "边界提醒"]
    },
    {
      "id": "case_reference",
      "name": "服务案例与公开实践",
      "output": ["案例背景", "服务动作", "可借鉴点", "风险边界", "可复用表达"]
    }
  ],
  "guardrails": {
    "deny": ["包装流水", "虚假材料", "套贷", "征信修复", "逃税", "规避监管"],
    "sensitive_info": ["身份证号", "银行卡号", "完整征信", "完整流水", "验证码", "账户密码"],
    "required_disclaimers": ["不构成贷款承诺", "不构成金融建议", "以官方渠道和合同约定为准"]
  },
  "recommended_questions": [
    "我是一家小店，想周转资金，先准备什么？",
    "小微企业贷款一般需要哪些材料？",
    "创业担保贷款怎么申请？",
    "帮我生成一份贷款用途说明。",
    "怎么判断贷款宣传是不是有风险？",
    "有哪些支持小微企业的政策？"
  ]
}
